<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2F7">

    <LinearLayout
        android:id="@+id/mainLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <!-- Dialer -->
        <Button
            android:id="@+id/btnDial"
            android:layout_width="280dp"
            android:layout_height="55dp"
            android:text="@string/open_dialer"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00695C"
            android:layout_margin="10dp"
            android:textAllCaps="false"/>

        <!-- Amazon -->
        <Button
            android:id="@+id/btnAmazon"
            android:layout_width="280dp"
            android:layout_height="55dp"
            android:text="@string/open_amazon"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00897B"
            android:layout_margin="10dp"
            android:textAllCaps="false"/>

        <!-- Maps -->
        <Button
            android:id="@+id/btnMaps"
            android:layout_width="280dp"
            android:layout_height="55dp"
            android:text="@string/open_google_maps"
            android:textColor="#FFFFFF"
            android:backgroundTint="#009688"
            android:layout_margin="10dp"
            android:textAllCaps="false"/>

        <!-- Gallery -->
        <Button
            android:id="@+id/btnGallery"
            android:layout_width="280dp"
            android:layout_height="55dp"
            android:text="@string/open_gallery"
            android:textColor="#FFFFFF"
            android:backgroundTint="#26A69A"
            android:layout_margin="10dp"
            android:textAllCaps="false"/>

        <!-- LinkedIn -->
        <Button
            android:id="@+id/btnLinkedIn"
            android:layout_width="280dp"
            android:layout_height="55dp"
            android:text="@string/open_linkedin"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4DB6AC"
            android:layout_margin="10dp"
            android:textAllCaps="false"/>

        <!-- YouTube -->
        <Button
            android:id="@+id/btnYoutube"
            android:layout_width="280dp"
            android:layout_height="55dp"
            android:text="@string/open_youtube"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00796B"
            android:layout_margin="10dp"
            android:textAllCaps="false"/>

        <!-- Instagram -->
        <Button
            android:id="@+id/btnInstagram"
            android:layout_width="280dp"
            android:layout_height="55dp"
            android:text="@string/open_instagram"
            android:textColor="#FFFFFF"
            android:backgroundTint="#004D40"
            android:layout_margin="10dp"
            android:textAllCaps="false"/>

        <!-- Snapchat -->
        <Button
            android:id="@+id/btnSnapchat"
            android:layout_width="280dp"
            android:layout_height="55dp"
            android:text="@string/open_snapchat"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32"
            android:layout_margin="10dp"
            android:textAllCaps="false"/>

        <!-- Back -->
        <Button
            android:id="@+id/btnBack"
            android:layout_width="280dp"
            android:layout_height="55dp"
            android:text="@string/back"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1B5E20"
            android:layout_margin="16dp"
            android:textAllCaps="false"/>

    </LinearLayout>
</ScrollView>